---
// src/pages/dashboard.astro
import DashboardLayout from '../layouts/DashboardLayout.astro';
import { getSession } from 'auth-astro/server';

// Busca a sessão do usuário logado
const session = await getSession(Astro.request);

// Proteção de Rota: Se não tiver sessão (não estiver logado), redireciona pro login
if (!session) {
  return Astro.redirect('/login');
}
---

<DashboardLayout>
  <div class="mb-8 flex justify-between items-end">
    <div>
      <h1 class="text-3xl font-bold text-gray-900">Visão Geral</h1>
      <p class="text-gray-500 mt-1">
        Bem-vindo de volta, <span class="font-semibold text-purple-600">{session?.user?.name || 'Gestor'}</span>! Acompanhe os resultados do G STORM hoje.
      </p>
    </div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
    
    <div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100 border-l-4 border-l-purple-600">
      <h3 class="text-sm font-medium text-gray-500 mb-2">Agendamentos Hoje</h3>
      <p class="text-3xl font-extrabold text-gray-900">5</p>
    </div>

    <div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100 border-l-4 border-l-black">
      <h3 class="text-sm font-medium text-gray-500 mb-2">Faturamento Esperado</h3>
      <p class="text-3xl font-extrabold text-gray-900">R$ 1.250</p>
    </div>

    <div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100 border-l-4 border-l-gray-300">
      <h3 class="text-sm font-medium text-gray-500 mb-2">Novos Clientes</h3>
      <p class="text-3xl font-extrabold text-gray-900">2</p>
    </div>

  </div>
  
  <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
    <div class="p-6 border-b border-gray-100 flex justify-between items-center">
      <h2 class="text-lg font-bold text-gray-900">Próximos Veículos</h2>
      <button class="text-sm text-purple-600 font-semibold hover:text-purple-800 transition-colors">
        Ver todos
      </button>
    </div>
    
    <div class="p-6">
      <div class="text-center py-10 text-gray-400 flex flex-col items-center">
        <svg class="w-12 h-12 mb-3 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path></svg>
        <p>A agenda de hoje está limpa.</p>
        <p class="text-sm mt-1">Nenhum veículo cadastrado no banco de dados ainda.</p>
      </div>
    </div>
  </div>
</DashboardLayout>