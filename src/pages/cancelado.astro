---
// src/pages/cancelado.astro
import DashboardLayout from '../layouts/DashboardLayout.astro';
---

<DashboardLayout>
  <div class="flex flex-col items-center justify-center min-h-[60vh] text-center px-4">
    <div class="w-20 h-20 bg-red-100 text-red-600 rounded-full flex items-center justify-center mb-6">
      <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
      </svg>
    </div>

    <h1 class="text-3xl font-black text-black tracking-tight mb-2">Pagamento não concluído</h1>
    <p class="text-gray-500 text-lg max-w-md mb-8">
      Não identificamos a conclusão do seu pagamento. Se houve algum erro com o seu cartão ou conexão, você pode tentar novamente.
    </p>

    <div class="flex flex-col sm:flex-row gap-4">
      <a href="/planos" class="px-8 py-4 bg-purple-600 text-white font-bold rounded-2xl hover:bg-purple-700 transition-all shadow-lg shadow-purple-500/30">
        Tentar Novamente
      </a>
      <a href="/dashboard" class="px-8 py-4 bg-gray-100 text-gray-700 font-bold rounded-2xl hover:bg-gray-200 transition-all">
        Voltar ao Início
      </a>
    </div>
  </div>
</DashboardLayout>