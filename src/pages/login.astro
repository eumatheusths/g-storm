---
// src/pages/login.astro
import { Image } from 'astro:assets';
// Importa a imagem direto da pasta assets
import bgCarro from '../assets/carro-luxo.jpg';
---

<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Login - G STORM</title>
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><rect width='100' height='100' rx='20' fill='%23000000'/><text x='50' y='72' font-family='system-ui, sans-serif' font-size='60' font-weight='900' text-anchor='middle'><tspan fill='%23ffffff'>G</tspan><tspan fill='%238b5cf6'>S</tspan></text></svg>" />
  </head>
  <body class="min-h-screen flex items-center justify-center p-4 font-sans selection:bg-purple-600 selection:text-white relative">
    
    <div class="absolute inset-0 z-0 overflow-hidden">
      <Image 
        src={bgCarro} 
        alt="Background Estética Automotiva" 
        format="webp"
        class="w-full h-full object-cover object-center"
      />
      <div class="absolute inset-0 bg-black/75 backdrop-blur-[2px]"></div>
    </div>

    <div class="w-full max-w-md bg-white rounded-2xl shadow-2xl p-8 relative z-10 overflow-hidden">
      
      <div class="absolute top-0 left-0 w-full h-2 bg-purple-600"></div>

      <div class="text-center mb-8 mt-4">
        <h1 class="text-4xl font-extrabold text-black tracking-tight">G <span class="text-purple-600">STORM</span></h1>
        <p class="text-sm text-gray-500 mt-2 font-medium uppercase tracking-widest">
          Gestão de Estética Automotiva
        </p>
      </div>

      <div class="space-y-6">
        <div>
          <h2 class="text-xl font-semibold text-black mb-1">Bem-vindo de volta</h2>
          <p class="text-gray-600 text-sm">Faça login para acessar o painel do sistema.</p>
        </div>

        <button 
          id="btn-google"
          class="w-full flex items-center justify-center gap-3 bg-black hover:bg-purple-600 text-white font-semibold py-3 px-4 rounded-xl transition-all duration-300 shadow-md hover:shadow-purple-600/30"
        >
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
            <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
            <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
            <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
          </svg>
          Continuar com Google
        </button>
      </div>

      <div class="mt-8 text-center">
        <p class="text-xs text-gray-400">
          Ao entrar, você concorda com nossos Termos de Serviço.
        </p>
      </div>
    </div>
  </body>
</html>

<script>
  import { signIn } from "auth-astro/client";
  
  const googleBtn = document.getElementById("btn-google");
  
  if (googleBtn) {
    googleBtn.addEventListener("click", (e) => {
      e.preventDefault(); 
      googleBtn.innerHTML = "Carregando o Google...";
      googleBtn.style.opacity = "0.7";
      signIn("google", { callbackUrl: "/dashboard" });
    });
  }
</script>