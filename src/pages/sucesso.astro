---
// src/pages/sucesso.astro
import DashboardLayout from '../layouts/DashboardLayout.astro';
---

<DashboardLayout>
  <div class="flex flex-col items-center justify-center min-h-[60vh] text-center px-4">
    <div class="w-20 h-20 bg-green-100 text-green-600 rounded-full flex items-center justify-center mb-6 animate-bounce">
      <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path>
      </svg>
    </div>

    <h1 class="text-4xl font-black text-black tracking-tight mb-2">Pagamento Recebido!</h1>
    <p class="text-gray-500 text-lg max-w-md mb-8">
      Parabéns, Matheus! Sua conta **G STORM PRO** está sendo liberada. Em instantes seu painel estará com todas as funções desbloqueadas.
    </p>

    <div class="flex flex-col sm:flex-row gap-4">
      <a href="/dashboard" class="px-8 py-4 bg-black text-white font-bold rounded-2xl hover:bg-purple-600 transition-all shadow-lg shadow-purple-500/20">
        Ir para o Painel
      </a>
      <a href="/servicos" class="px-8 py-4 bg-gray-100 text-gray-700 font-bold rounded-2xl hover:bg-gray-200 transition-all">
        Configurar Serviços
      </a>
    </div>

    <p class="text-gray-400 text-xs mt-12">
      O processamento pode levar até 2 minutos dependendo da sua operadora.
    </p>
  </div>
</DashboardLayout>