---
// src/pages/agendar/[slug].astro
import { db } from '../../db';
import { users, agendamentos } from '../../db/schema';
import { eq } from 'drizzle-orm';

// 1. Captura o nome da estética pela URL
const { slug } = Astro.params;

// 2. Busca a estética no banco de dados
const companyArray = await db.select().from(users).where(eq(users.slug, slug as string)).limit(1);
const company = companyArray[0];

// Se digitar um link que não existe, mostra erro 404
if (!company) {
  return new Response("Página não encontrada ou link inválido.", { status: 404 });
}

let sucesso = false;

// 3. Lógica para salvar o agendamento quando o cliente enviar o formulário
if (Astro.request.method === 'POST') {
  try {
    const formData = await Astro.request.formData();
    
    // Captura os dados do formulário
    const clienteNome = formData.get('clienteNome')?.toString() || '';
    const clienteWhatsapp = formData.get('clienteWhatsapp')?.toString() || '';
    const veiculoModelo = formData.get('veiculoModelo')?.toString() || '';
    const veiculoPlaca = formData.get('veiculoPlaca')?.toString() || '';
    const servicoDesejado = formData.get('servicoDesejado')?.toString() || '';
    const detalhesEstadoCarro = formData.get('detalhesEstadoCarro')?.toString() || '';
    
    // Ajuste de data e hora
    const dataInput = formData.get('dataAgendamento')?.toString() || '';
    const dataAgendamento = new Date(dataInput);
    // Adiciona o fuso horário para evitar que caia no dia anterior no banco
    dataAgendamento.setMinutes(dataAgendamento.getMinutes() + dataAgendamento.getTimezoneOffset());
    
    const horaAgendamento = formData.get('horaAgendamento')?.toString() || '';

    // Salva no Neon
    await db.insert(agendamentos).values({
      userId: company.id,
      clienteNome,
      clienteWhatsapp,
      veiculoModelo,
      veiculoPlaca,
      servicoDesejado,
      detalhesEstadoCarro,
      dataAgendamento,
      horaAgendamento,
      status: 'pendente' // Cai como pendente no painel do dono
    });

    sucesso = true;
  } catch (error) {
    console.error("Erro ao salvar agendamento:", error);
  }
}
---

<html lang="pt-BR" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Agendamento - {company.companyName}</title>
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  </head>
  <body class="bg-black text-white font-sans antialiased min-h-screen flex flex-col items-center py-10 px-4">
    
    <div class="w-full max-w-lg relative z-10">
      <div class="text-center mb-10">
        <div class="w-20 h-20 bg-purple-600/20 text-purple-500 rounded-full flex items-center justify-center mx-auto mb-4 border border-purple-500/30 shadow-[0_0_15px_rgba(139,92,246,0.2)]">
          <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path></svg>
        </div>
        <h1 class="text-3xl font-black tracking-tight">{company.companyName}</h1>
        <p class="text-gray-400 mt-2 text-sm">Preencha os dados abaixo para solicitar seu horário em nosso estúdio.</p>
      </div>

      {sucesso ? (
        <div class="bg-gray-900 border border-purple-500/30 p-8 rounded-3xl text-center shadow-2xl">
          <div class="w-16 h-16 bg-green-500/20 text-green-400 rounded-full flex items-center justify-center mx-auto mb-6">
            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
          </div>
          <h2 class="text-2xl font-bold mb-3 text-white">Solicitação Recebida!</h2>
          <p class="text-gray-400 mb-8 leading-relaxed">Sua pré-reserva foi enviada para o nosso pátio. Nossa equipe avaliará a disponibilidade e confirmará tudo com você via WhatsApp em breve.</p>
          <a href="#" onclick="window.close()" class="block w-full py-4 bg-white text-black font-bold rounded-xl hover:bg-gray-200 transition-colors">
            Fechar
          </a>
        </div>
      ) : (
        <div class="bg-gray-900 border border-gray-800 p-6 sm:p-8 rounded-3xl shadow-2xl">
          <form method="POST" class="space-y-8">
            
            <div>
              <h3 class="text-lg font-bold text-purple-400 border-b border-gray-800 pb-2 mb-4 flex items-center gap-2">
                <span class="bg-purple-600 text-white w-6 h-6 rounded-full flex items-center justify-center text-xs">1</span> 
                Seus Dados e Veículo
              </h3>
              <div class="space-y-4">
                <div>
                  <label class="block text-sm font-medium text-gray-300 mb-1">Seu Nome</label>
                  <input type="text" name="clienteNome" required placeholder="João da Silva" class="w-full bg-black border border-gray-700 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-purple-500 transition-all" />
                </div>
                <div>
                  <label class="block text-sm font-medium text-gray-300 mb-1">Seu WhatsApp</label>
                  <input type="tel" name="clienteWhatsapp" required placeholder="(00) 00000-0000" class="w-full bg-black border border-gray-700 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-purple-500 transition-all" />
                </div>
                <div class="grid grid-cols-2 gap-4">
                  <div>
                    <label class="block text-sm font-medium text-gray-300 mb-1">Veículo</label>
                    <input type="text" name="veiculoModelo" required placeholder="Ex: BMW 320i" class="w-full bg-black border border-gray-700 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-purple-500 transition-all" />
                  </div>
                  <div>
                    <label class="block text-sm font-medium text-gray-300 mb-1">Placa</label>
                    <input type="text" name="veiculoPlaca" required placeholder="ABC-1234" class="w-full bg-black border border-gray-700 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-purple-500 transition-all uppercase" />
                  </div>
                </div>
              </div>
            </div>

            <div>
              <h3 class="text-lg font-bold text-purple-400 border-b border-gray-800 pb-2 mb-4 flex items-center gap-2">
                <span class="bg-purple-600 text-white w-6 h-6 rounded-full flex items-center justify-center text-xs">2</span> 
                O que faremos hoje?
              </h3>
              <div class="space-y-4">
                <div>
                  <label class="block text-sm font-medium text-gray-300 mb-1">Serviço Principal</label>
                  <select name="servicoDesejado" required class="w-full bg-black border border-gray-700 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-purple-500 transition-all appearance-none">
                    <option value="" disabled selected>Selecione um serviço...</option>
                    <option value="Lavagem Detalhada">Lavagem Detalhada</option>
                    <option value="Polimento Comercial">Polimento Comercial</option>
                    <option value="Polimento Técnico">Polimento Técnico</option>
                    <option value="Vitrificação de Pintura">Vitrificação de Pintura</option>
                    <option value="Higienização Interna">Higienização Interna</option>
                    <option value="Outro (Avaliação)">Outro (Preciso de avaliação)</option>
                  </select>
                </div>
                <div>
                  <label class="block text-sm font-medium text-gray-300 mb-1">Como está o carro? (Opcional)</label>
                  <textarea name="detalhesEstadoCarro" rows="2" placeholder="Ex: Pintura com arranhões de gato, bancos manchados..." class="w-full bg-black border border-gray-700 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-purple-500 transition-all resize-none"></textarea>
                </div>
              </div>
            </div>

            <div>
              <h3 class="text-lg font-bold text-purple-400 border-b border-gray-800 pb-2 mb-4 flex items-center gap-2">
                <span class="bg-purple-600 text-white w-6 h-6 rounded-full flex items-center justify-center text-xs">3</span> 
                Disponibilidade
              </h3>
              <div class="grid grid-cols-2 gap-4">
                <div>
                  <label class="block text-sm font-medium text-gray-300 mb-1">Data</label>
                  <input type="date" name="dataAgendamento" required class="w-full bg-black border border-gray-700 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-purple-500 transition-all" style="color-scheme: dark;" />
                </div>
                <div>
                  <label class="block text-sm font-medium text-gray-300 mb-1">Hora Ideal</label>
                  <input type="time" name="horaAgendamento" required class="w-full bg-black border border-gray-700 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-purple-500 transition-all" style="color-scheme: dark;" />
                </div>
              </div>
            </div>

            <button type="submit" class="w-full py-4 bg-purple-600 hover:bg-purple-500 text-white font-bold text-lg rounded-xl transition-all shadow-[0_0_20px_rgba(124,58,237,0.3)] mt-4">
              Solicitar Agendamento
            </button>
            <p class="text-xs text-gray-500 text-center mt-4">
              Ao enviar, você concorda que o horário está sujeito à confirmação do estúdio.
            </p>
          </form>
        </div>
      )}
      
      <div class="mt-8 text-center text-xs text-gray-600">
        Desenvolvido por <a href="https://g-storm.vercel.app" class="font-bold text-gray-400 hover:text-purple-400 transition-colors">G STORM</a>
      </div>
    </div>
  </body>
</html>