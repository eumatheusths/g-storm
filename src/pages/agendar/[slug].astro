---
// src/pages/agendar/[slug].astro
import { db } from '../../db';
import { users, agendamentos, configuracoesServico } from '../../db/schema';
import { eq } from 'drizzle-orm';

const { slug } = Astro.params;

// 1. Busca a Estética
const companyArray = await db.select().from(users).where(eq(users.slug, slug as string)).limit(1);
const company = companyArray[0];

if (!company) {
  return new Response("Página não encontrada ou link inválido.", { status: 404 });
}

// 2. Busca o Catálogo de Serviços do Dono da Estética
const servicosDaEstetica = await db.select().from(configuracoesServico).where(eq(configuracoesServico.userId, company.id));

// 3. Busca os Agendamentos (Para o Calendário)
const bookedAgendamentos = await db.select({
  data: agendamentos.dataAgendamento,
  hora: agendamentos.horaAgendamento,
  duracao: agendamentos.duracaoMinutos
}).from(agendamentos).where(eq(agendamentos.userId, company.id));

const bookedSlots = bookedAgendamentos.map(a => {
  const d = new Date(a.data);
  const yyyy = d.getFullYear();
  const mm = String(d.getMonth() + 1).padStart(2, '0');
  const dd = String(d.getDate()).padStart(2, '0');
  return { date: `${yyyy}-${mm}-${dd}`, time: a.hora, duracao: a.duracao };
});

let sucesso = false;

// 4. Salva o Agendamento Completo
if (Astro.request.method === 'POST') {
  try {
    const formData = await Astro.request.formData();
    
    // Dados Pessoais
    const clienteNome = formData.get('clienteNome')?.toString() || '';
    const clienteWhatsapp = formData.get('clienteWhatsapp')?.toString() || '';
    
    // Veículo
    const veiculoModelo = formData.get('veiculoModelo')?.toString() || '';
    const veiculoPlaca = formData.get('veiculoPlaca')?.toString() || '';
    const categoriaVeiculo = formData.get('categoriaVeiculo')?.toString() || '';
    
    // Serviço e Estado
    const servicoDesejado = formData.get('servicoDesejado')?.toString() || '';
    const duracaoMinutos = parseInt(formData.get('duracaoMinutos')?.toString() || '60');
    const detalhesEstadoCarro = formData.get('detalhesEstadoCarro')?.toString() || '';
    const nivelSujeira = formData.get('nivelSujeira')?.toString() || 'Médio';
    const fotoVeiculo = formData.get('fotoBase64')?.toString() || null;
    
    // Data e Hora Ocultas
    const dataInput = formData.get('hiddenDate')?.toString() || '';
    const dataAgendamento = new Date(dataInput);
    dataAgendamento.setMinutes(dataAgendamento.getMinutes() + dataAgendamento.getTimezoneOffset());
    const horaAgendamento = formData.get('hiddenTime')?.toString() || '';

    // Insere no Banco
    await db.insert(agendamentos).values({
      userId: company.id,
      clienteNome,
      clienteWhatsapp,
      veiculoModelo,
      veiculoPlaca,
      categoriaVeiculo,
      servicoDesejado,
      duracaoMinutos,
      detalhesEstadoCarro,
      nivelSujeira,
      fotoVeiculo,
      dataAgendamento,
      horaAgendamento,
      status: 'pendente'
    });

    sucesso = true;
  } catch (error) {
    console.error("Erro ao salvar:", error);
  }
}
---

<html lang="pt-BR" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Agendamento - {company.companyName}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  </head>
  <body class="bg-black text-white font-sans antialiased min-h-screen flex flex-col items-center py-10 px-4">
    
    <div id="dados-servicos" data-services={JSON.stringify(servicosDaEstetica)} class="hidden"></div>
    <div id="dados-agendamentos" data-booked={JSON.stringify(bookedSlots)} class="hidden"></div>

    <div class="w-full max-w-lg relative z-10">
      
      <div class="text-center mb-8">
        <div class="w-16 h-16 bg-purple-600/20 text-purple-500 rounded-full flex items-center justify-center mx-auto mb-4 border border-purple-500/30">
          <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
        </div>
        <h1 class="text-3xl font-black tracking-tight">{company.companyName}</h1>
      </div>

      {sucesso ? (
        <div class="bg-gray-900 border border-purple-500/30 p-8 rounded-3xl text-center shadow-2xl">
          <div class="w-16 h-16 bg-green-500/20 text-green-400 rounded-full flex items-center justify-center mx-auto mb-6">
            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
          </div>
          <h2 class="text-2xl font-bold mb-3 text-white">Serviço Solicitado!</h2>
          <p class="text-gray-400 mb-8">Sua pré-reserva foi enviada para o pátio. Nossa equipe avaliará a disponibilidade e confirmará com você via WhatsApp.</p>
          <button onclick="window.close()" class="w-full py-4 bg-white text-black font-bold rounded-xl hover:bg-gray-200 transition-colors">
            Fechar Janela
          </button>
        </div>
      ) : servicosDaEstetica.length === 0 ? (
        <div class="bg-gray-900 border border-gray-800 p-8 rounded-3xl text-center shadow-2xl">
          <h2 class="text-xl font-bold mb-3 text-white">Estúdio em Configuração</h2>
          <p class="text-gray-400">Este estúdio ainda não configurou o catálogo de serviços. Volte mais tarde.</p>
        </div>
      ) : (
        
        <form method="POST" id="form-agendamento" class="bg-gray-900 border border-gray-800 p-6 sm:p-8 rounded-3xl shadow-2xl relative overflow-hidden">
          
          <input type="hidden" name="hiddenDate" id="hiddenDate" />
          <input type="hidden" name="hiddenTime" id="hiddenTime" />
          <input type="hidden" name="duracaoMinutos" id="duracaoMinutos" value="60" />

          <div id="step-1" class="transition-all duration-300 space-y-6">
            
            <h3 class="text-xl font-bold text-white mb-2 text-center border-b border-gray-800 pb-4">Detalhes do Serviço</h3>
            
            <div class="space-y-4">
              <div>
                <label class="block text-sm font-medium text-gray-300 mb-1">Seu Nome</label>
                <input type="text" name="clienteNome" required placeholder="Ex: João da Silva" class="w-full bg-black border border-gray-700 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-purple-500 transition-all" />
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-300 mb-1">WhatsApp</label>
                <input type="tel" name="clienteWhatsapp" required placeholder="(00) 00000-0000" class="w-full bg-black border border-gray-700 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-purple-500 transition-all" />
              </div>

              <div>
                <label class="block text-sm font-medium text-gray-300 mb-1">Qual serviço você deseja?</label>
                <select name="servicoDesejado" id="select-servico" required class="w-full bg-black border border-gray-700 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-purple-500 transition-all appearance-none">
                  <option value="" disabled selected>Selecione um serviço...</option>
                  </select>
              </div>

              <div>
                <label class="block text-sm font-medium text-gray-300 mb-1">Porte do Veículo</label>
                <select name="categoriaVeiculo" id="select-porte" required disabled class="w-full bg-black border border-gray-700 rounded-xl px-4 py-3 text-gray-400 disabled:opacity-50 focus:outline-none focus:border-purple-500 transition-all appearance-none">
                  <option value="" disabled selected>Escolha o serviço primeiro...</option>
                  </select>
              </div>

              <div class="grid grid-cols-2 gap-4">
                <div>
                  <label class="block text-sm font-medium text-gray-300 mb-1">Modelo Real</label>
                  <input type="text" name="veiculoModelo" required placeholder="Ex: BMW 320i" class="w-full bg-black border border-gray-700 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-purple-500 transition-all" />
                </div>
                <div>
                  <label class="block text-sm font-medium text-gray-300 mb-1">Placa</label>
                  <input type="text" name="veiculoPlaca" required placeholder="ABC-1234" class="w-full bg-black border border-gray-700 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-purple-500 transition-all uppercase" />
                </div>
              </div>

              <div>
                <label class="block text-sm font-medium text-gray-300 mb-1">Nível de Sujeira</label>
                <div class="grid grid-cols-3 gap-3">
                  <label class="cursor-pointer">
                    <input type="radio" name="nivelSujeira" value="Pouco" class="peer sr-only" checked />
                    <div class="text-center p-3 rounded-xl bg-black border border-gray-700 peer-checked:border-green-500 peer-checked:bg-green-500/10 transition-all">
                      <span class="block text-xl mb-1">✨</span>
                      <span class="text-xs font-bold text-gray-300 peer-checked:text-green-400">Pouco</span>
                    </div>
                  </label>
                  <label class="cursor-pointer">
                    <input type="radio" name="nivelSujeira" value="Médio" class="peer sr-only" />
                    <div class="text-center p-3 rounded-xl bg-black border border-gray-700 peer-checked:border-yellow-500 peer-checked:bg-yellow-500/10 transition-all">
                      <span class="block text-xl mb-1">🛣️</span>
                      <span class="text-xs font-bold text-gray-300 peer-checked:text-yellow-400">Médio</span>
                    </div>
                  </label>
                  <label class="cursor-pointer">
                    <input type="radio" name="nivelSujeira" value="Muito" class="peer sr-only" />
                    <div class="text-center p-3 rounded-xl bg-black border border-gray-700 peer-checked:border-red-500 peer-checked:bg-red-500/10 transition-all">
                      <span class="block text-xl mb-1">🚜</span>
                      <span class="text-xs font-bold text-gray-300 peer-checked:text-red-400">Muito</span>
                    </div>
                  </label>
                </div>
              </div>

              <div>
                <label class="block text-sm font-medium text-gray-300 mb-2">Foto do Veículo (Opcional)</label>
                <input type="hidden" name="fotoBase64" id="fotoBase64" />
                
                <label for="fotoUpload" class="flex flex-col items-center justify-center w-full h-32 border-2 border-dashed border-gray-700 hover:border-purple-500 rounded-xl bg-black cursor-pointer transition-colors group relative overflow-hidden">
                  <div id="uploadPlaceholder" class="flex flex-col items-center justify-center pt-5 pb-6">
                    <svg class="w-8 h-8 text-gray-500 group-hover:text-purple-400 mb-2 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                    <p class="text-sm text-gray-400 font-medium">Tirar foto ou anexar</p>
                  </div>
                  <img id="imagePreview" class="absolute inset-0 w-full h-full object-cover hidden opacity-80" />
                  <input id="fotoUpload" type="file" accept="image/*" class="hidden" capture="environment" />
                </label>
              </div>

              <button type="button" id="btn-ir-calendario" class="w-full py-4 bg-purple-600 hover:bg-purple-500 text-white font-bold text-lg rounded-xl transition-all shadow-[0_0_20px_rgba(124,58,237,0.3)] mt-6 flex justify-center items-center gap-2">
                Escolher Data e Hora
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
              </button>
            </div>
          </div>

          <div id="step-2" class="hidden transition-all duration-300">
            <button type="button" id="btn-voltar" class="text-sm text-gray-400 hover:text-white mb-6 flex items-center gap-1 transition-colors">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
              Voltar aos dados
            </button>

            <h3 class="text-xl font-bold text-white mb-6 text-center">Disponibilidade do Pátio</h3>
            
            <div class="space-y-6">
              <div>
                <label class="block text-sm font-medium text-gray-400 mb-2">1. Selecione a Data</label>
                <input type="date" id="date-picker" class="w-full bg-black border border-gray-700 rounded-xl px-4 py-4 text-white font-bold focus:outline-none focus:border-purple-500 transition-all text-center text-lg" style="color-scheme: dark;" />
              </div>

              <div id="time-container" class="hidden">
                <label class="block text-sm font-medium text-gray-400 mb-2">2. Escolha o Horário <span class="text-xs font-normal text-purple-400">(Calculado para o seu veículo)</span></label>
                <div id="time-grid" class="grid grid-cols-3 gap-3"></div>
              </div>

              <button type="submit" id="btn-finalizar" class="hidden w-full py-4 bg-green-600 hover:bg-green-500 text-white font-bold text-lg rounded-xl transition-all shadow-[0_0_20px_rgba(22,163,74,0.3)] mt-6 flex justify-center items-center gap-2">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                Confirmar Agendamento
              </button>
            </div>
          </div>
        </form>
      )}

      <div class="mt-8 text-center text-xs text-gray-600">
        Desenvolvido por <a href="https://g-storm.vercel.app" class="font-bold text-gray-400 hover:text-purple-400 transition-colors">G STORM</a>
      </div>
    </div>
  </body>
</html>

<script>
  // 1. CARREGA DADOS DO BANCO
  const servicesEl = document.getElementById('dados-servicos');
  const bookedEl = document.getElementById('dados-agendamentos');
  
  const servicesData = servicesEl ? JSON.parse(servicesEl.getAttribute('data-services') || '[]') : [];
  const bookedSlots = bookedEl ? JSON.parse(bookedEl.getAttribute('data-booked') || '[]') : [];

  // 2. ELEMENTOS DO DOM (SERVIÇOS)
  const selectServico = document.getElementById('select-servico') as HTMLSelectElement;
  const selectPorte = document.getElementById('select-porte') as HTMLSelectElement;
  const inputDuracao = document.getElementById('duracaoMinutos') as HTMLInputElement;

  if (selectServico && servicesData.length > 0) {
    // Extrai nomes únicos de serviços
    const uniqueServices = [...new Set(servicesData.map((s: any) => s.nomeServico))];
    uniqueServices.forEach(nome => {
      selectServico.add(new Option(nome as string, nome as string));
    });

    // Quando escolhe o serviço, destrava o porte
    selectServico.addEventListener('change', (e) => {
      const servicoEscolhido = (e.target as HTMLSelectElement).value;
      const portesDisponiveis = servicesData.filter((s: any) => s.nomeServico === servicoEscolhido);
      
      selectPorte.innerHTML = '<option value="" disabled selected>Selecione o porte...</option>';
      portesDisponiveis.forEach((p: any) => {
        selectPorte.add(new Option(p.categoriaVeiculo, p.categoriaVeiculo));
      });
      
      selectPorte.disabled = false;
      selectPorte.classList.remove('text-gray-400');
      selectPorte.classList.add('text-white');
    });

    // Quando escolhe o porte, acha o tempo de duração
    selectPorte.addEventListener('change', (e) => {
      const servicoEscolhido = selectServico.value;
      const porteEscolhido = (e.target as HTMLSelectElement).value;
      
      const configExata = servicesData.find((s: any) => s.nomeServico === servicoEscolhido && s.categoriaVeiculo === porteEscolhido);
      if (configExata) {
        inputDuracao.value = configExata.duracaoMinutos;
      }
    });
  }

  // 3. COMPRESSÃO DA FOTO (BASE64)
  const fotoUpload = document.getElementById('fotoUpload') as HTMLInputElement;
  const fotoBase64 = document.getElementById('fotoBase64') as HTMLInputElement;
  const imagePreview = document.getElementById('imagePreview') as HTMLImageElement;
  const uploadPlaceholder = document.getElementById('uploadPlaceholder');

  if (fotoUpload) {
    fotoUpload.addEventListener('change', function(e) {
      const file = (e.target as HTMLInputElement).files?.[0];
      if (!file) return;

      const reader = new FileReader();
      reader.onload = function(event) {
        const img = new Image();
        img.onload = function() {
          const canvas = document.createElement('canvas');
          const ctx = canvas.getContext('2d');
          let width = img.width, height = img.height;
          const max_size = 800; 
          
          if (width > height) {
            if (width > max_size) { height *= max_size / width; width = max_size; }
          } else {
            if (height > max_size) { width *= max_size / height; height = max_size; }
          }
          
          canvas.width = width; canvas.height = height;
          ctx?.drawImage(img, 0, 0, width, height);
          
          const base64String = canvas.toDataURL('image/jpeg', 0.6);
          if (fotoBase64) fotoBase64.value = base64String;

          if (imagePreview && uploadPlaceholder) {
            imagePreview.src = base64String;
            imagePreview.classList.remove('hidden');
            uploadPlaceholder.classList.add('hidden');
          }
        }
        img.src = event.target?.result as string;
      }
      reader.readAsDataURL(file);
    });
  }

  // 4. LÓGICA DE NAVEGAÇÃO E CALENDÁRIO INTELIGENTE
  const btnIrCalendario = document.getElementById('btn-ir-calendario');
  const btnVoltar = document.getElementById('btn-voltar');
  const btnFinalizar = document.getElementById('btn-finalizar');
  const step1 = document.getElementById('step-1');
  const step2 = document.getElementById('step-2');
  
  const datePicker = document.getElementById('date-picker') as HTMLInputElement;
  const timeContainer = document.getElementById('time-container');
  const timeGrid = document.getElementById('time-grid');
  const hiddenDate = document.getElementById('hiddenDate') as HTMLInputElement;
  const hiddenTime = document.getElementById('hiddenTime') as HTMLInputElement;

  // Navegação
  if (btnIrCalendario && btnVoltar && step1 && step2) {
    btnIrCalendario.addEventListener('click', () => {
      // Validação simples antes de ir pro calendário
      const form = document.getElementById('form-agendamento') as HTMLFormElement;
      if(!form.checkValidity()) {
        form.reportValidity();
        return;
      }
      step1.classList.add('hidden');
      step2.classList.remove('hidden');
    });

    btnVoltar.addEventListener('click', () => {
      step2.classList.add('hidden');
      step1.classList.remove('hidden');
    });
  }

  // Lógica do Calendário com Cálculo de Blocos
  if (datePicker && timeGrid) {
    const today = new Date().toISOString().split('T')[0];
    datePicker.min = today;

    // Horários de 1 em 1 hora
    const horasFuncionamento = [8, 9, 10, 11, 13, 14, 15, 16, 17]; 

    datePicker.addEventListener('change', (e) => {
      const dataEscolhida = (e.target as HTMLInputElement).value;
      if (!dataEscolhida) return;

      hiddenDate.value = dataEscolhida;
      timeContainer?.classList.remove('hidden');
      timeGrid.innerHTML = '';
      btnFinalizar?.classList.add('hidden');

      // Quantos "blocos de hora" esse serviço ocupa?
      const duracaoServico = parseInt(inputDuracao.value || '60');
      const blocosNecessarios = Math.ceil(duracaoServico / 60);

      // Filtra os agendamentos já marcados para o dia escolhido
      const marcadosNoDia = bookedSlots.filter((slot: any) => slot.date === dataEscolhida);

      horasFuncionamento.forEach(horaInt => {
        const horaString = `${String(horaInt).padStart(2, '0')}:00`;
        const btn = document.createElement('button');
        btn.type = 'button';
        btn.innerText = horaString;
        
        let slotOcupado = false;

        // Verifica se ESSA hora bate com algum serviço que já está rolando
        marcadosNoDia.forEach((marcado: any) => {
           const horaMarcada = parseInt(marcado.time.split(':')[0]);
           const blocosOcupados = Math.ceil(marcado.duracao / 60);
           
           // Se a hora que estamos gerando cai no meio de um serviço marcado, bloqueia!
           if (horaInt >= horaMarcada && horaInt < (horaMarcada + blocosOcupados)) {
               slotOcupado = true;
           }
           
           // Evita que o novo serviço "atropele" o próximo se for muito longo
           if (horaInt < horaMarcada && (horaInt + blocosNecessarios) > horaMarcada) {
               slotOcupado = true;
           }
        });

        if (slotOcupado) {
          btn.className = 'py-3 rounded-xl bg-gray-800 text-gray-500 line-through cursor-not-allowed opacity-50 font-medium text-sm';
          btn.disabled = true;
        } else {
          btn.className = 'py-3 rounded-xl bg-gray-900 border border-gray-700 text-white hover:border-purple-500 transition-all font-bold text-sm time-btn';
          btn.onclick = () => {
            // Lógica visual de seleção
            document.querySelectorAll('.time-btn').forEach(b => {
              b.classList.remove('bg-purple-600', 'border-purple-500', 'shadow-[0_0_15px_rgba(139,92,246,0.3)]');
              b.classList.add('bg-gray-900', 'border-gray-700');
            });
            btn.classList.remove('bg-gray-900', 'border-gray-700');
            btn.classList.add('bg-purple-600', 'border-purple-500', 'shadow-[0_0_15px_rgba(139,92,246,0.3)]');
            
            hiddenTime.value = horaString;
            btnFinalizar?.classList.remove('hidden');
          };
        }
        timeGrid.appendChild(btn);
      });
    });
  }
</script>