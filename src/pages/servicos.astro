---
// src/pages/servicos.astro
import DashboardLayout from '../layouts/DashboardLayout.astro';
import { getSession } from 'auth-astro/server';
import { db } from '../db';
import { users, configuracoesServico } from '../db/schema';
import { eq } from 'drizzle-orm';

const session = await getSession(Astro.request);
if (!session?.user?.email) {
  return Astro.redirect('/login');
}

const userDbArray = await db.select().from(users).where(eq(users.email, session.user.email)).limit(1);
const userDb = userDbArray[0];

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const action = formData.get('action')?.toString();

  if (action === 'add') {
    const nomeServico = formData.get('nomeServico')?.toString();
    const categoriaVeiculo = formData.get('categoriaVeiculo')?.toString();
    const duracaoMinutos = parseInt(formData.get('duracaoMinutos')?.toString() || '0');
    
    // Capturando os 3 novos preços
    const precoPoucoSujo = parseInt(formData.get('precoPoucoSujo')?.toString() || '0');
    const precoMedio = parseInt(formData.get('precoMedio')?.toString() || '0');
    const precoMuitoSujo = parseInt(formData.get('precoMuitoSujo')?.toString() || '0');

    if (nomeServico && categoriaVeiculo && duracaoMinutos > 0) {
      await db.insert(configuracoesServico).values({
        userId: userDb.id,
        nomeServico,
        categoriaVeiculo,
        duracaoMinutos,
        precoPoucoSujo,
        precoMedio,
        precoMuitoSujo
      });
    }
  } 
  else if (action === 'delete') {
    const idParaDeletar = formData.get('id')?.toString();
    if (idParaDeletar) {
      await db.delete(configuracoesServico).where(eq(configuracoesServico.id, idParaDeletar));
    }
  }
}

const meusServicos = await db.select().from(configuracoesServico).where(eq(configuracoesServico.userId, userDb.id));
---

<DashboardLayout>
  <div class="space-y-8 max-w-6xl mx-auto">
    
    <div>
      <h1 class="text-3xl font-black text-black tracking-tight">Catálogo de Serviços</h1>
      <p class="text-gray-500 mt-1">Configure o tempo e a tabela de preços baseada no nível de sujeira do veículo.</p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 items-start">
      
      <div class="lg:col-span-1 bg-white p-6 rounded-2xl shadow-sm border border-gray-200">
        <h2 class="text-lg font-bold text-black mb-4 flex items-center gap-2">
          <svg class="w-5 h-5 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
          Novo Serviço
        </h2>
        
        <form method="POST" class="space-y-4">
          <input type="hidden" name="action" value="add" />
          
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Nome do Serviço</label>
            <input type="text" name="nomeServico" required placeholder="Ex: Lavagem Detalhada" class="w-full bg-gray-50 border border-gray-300 rounded-xl px-4 py-2.5 text-black focus:outline-none focus:border-purple-500 transition-all" />
          </div>
          
          <div class="grid grid-cols-2 gap-3">
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Porte</label>
              <input type="text" name="categoriaVeiculo" required placeholder="Ex: SUV" class="w-full bg-gray-50 border border-gray-300 rounded-xl px-4 py-2.5 text-black focus:outline-none focus:border-purple-500 transition-all" />
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Tempo (Min)</label>
              <input type="number" name="duracaoMinutos" required placeholder="Ex: 120" class="w-full bg-gray-50 border border-gray-300 rounded-xl px-4 py-2.5 text-black focus:outline-none focus:border-purple-500 transition-all" />
            </div>
          </div>
          
          <div class="pt-2 border-t border-gray-100 mt-2">
            <label class="block text-sm font-bold text-gray-800 mb-2">Tabela de Preços (R$)</label>
            <div class="grid grid-cols-3 gap-2">
              <div>
                <span class="text-[10px] uppercase font-bold text-green-600 mb-1 block text-center">✨ Pouco</span>
                <input type="number" name="precoPoucoSujo" required placeholder="Ex: 80" class="w-full bg-green-50 border border-green-200 rounded-xl px-2 py-2 text-black text-center focus:outline-none focus:border-green-500 transition-all" />
              </div>
              <div>
                <span class="text-[10px] uppercase font-bold text-yellow-600 mb-1 block text-center">🛣️ Médio</span>
                <input type="number" name="precoMedio" required placeholder="Ex: 100" class="w-full bg-yellow-50 border border-yellow-200 rounded-xl px-2 py-2 text-black text-center focus:outline-none focus:border-yellow-500 transition-all" />
              </div>
              <div>
                <span class="text-[10px] uppercase font-bold text-red-600 mb-1 block text-center">🚜 Muito</span>
                <input type="number" name="precoMuitoSujo" required placeholder="Ex: 140" class="w-full bg-red-50 border border-red-200 rounded-xl px-2 py-2 text-black text-center focus:outline-none focus:border-red-500 transition-all" />
              </div>
            </div>
          </div>
          
          <button type="submit" class="w-full py-3 mt-4 bg-black hover:bg-purple-600 text-white font-bold rounded-xl transition-all shadow-md">
            Cadastrar Serviço
          </button>
        </form>
      </div>

      <div class="lg:col-span-2 bg-white p-6 rounded-2xl shadow-sm border border-gray-200">
        <h2 class="text-lg font-bold text-black mb-4">Meus Serviços</h2>
        
        {meusServicos.length === 0 ? (
          <div class="text-center py-12 border-2 border-dashed border-gray-200 rounded-xl">
            <p class="text-gray-500 font-medium">Nenhum serviço cadastrado ainda.</p>
          </div>
        ) : (
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            {meusServicos.map((servico) => (
              <div class="border border-gray-200 rounded-xl p-4 hover:border-purple-300 transition-colors relative group bg-white shadow-sm">
                
                <form method="POST" class="absolute top-3 right-3 opacity-0 group-hover:opacity-100 transition-opacity">
                  <input type="hidden" name="action" value="delete" />
                  <input type="hidden" name="id" value={servico.id} />
                  <button type="submit" class="text-red-400 hover:text-red-600 bg-red-50 hover:bg-red-100 p-1.5 rounded-lg transition-colors" title="Excluir Serviço">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                  </button>
                </form>

                <h3 class="font-bold text-black mb-1 pr-8">{servico.nomeServico}</h3>
                <div class="flex gap-2 mb-3">
                  <span class="inline-block px-2 py-1 bg-gray-100 text-gray-700 text-xs font-semibold rounded-md">
                    {servico.categoriaVeiculo}
                  </span>
                  <span class="inline-block px-2 py-1 bg-purple-50 text-purple-700 text-xs font-semibold rounded-md flex items-center gap-1">
                    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                    {servico.duracaoMinutos} min
                  </span>
                </div>
                
                <div class="bg-gray-50 rounded-lg p-3 space-y-1.5 border border-gray-100">
                  <div class="flex justify-between items-center text-sm">
                    <span class="text-green-700 font-medium flex items-center gap-1"><span class="text-[10px]">✨</span> Pouco Sujo</span>
                    <span class="font-bold text-black">R$ {servico.precoPoucoSujo},00</span>
                  </div>
                  <div class="flex justify-between items-center text-sm">
                    <span class="text-yellow-700 font-medium flex items-center gap-1"><span class="text-[10px]">🛣️</span> Médio</span>
                    <span class="font-bold text-black">R$ {servico.precoMedio},00</span>
                  </div>
                  <div class="flex justify-between items-center text-sm">
                    <span class="text-red-700 font-medium flex items-center gap-1"><span class="text-[10px]">🚜</span> Muito Sujo</span>
                    <span class="font-bold text-black">R$ {servico.precoMuitoSujo},00</span>
                  </div>
                </div>

              </div>
            ))}
          </div>
        )}
      </div>

    </div>
  </div>
</DashboardLayout>