---
// src/layouts/DashboardLayout.astro
import { getSession } from 'auth-astro/server';
import { db } from '../db';
import { users } from '../db/schema';
import { eq } from 'drizzle-orm';

const session = await getSession(Astro.request);

let diasRestantes = 0;
let isExpirado = false;

if (session?.user?.email) {
  const resultado = await db.select().from(users).where(eq(users.email, session.user.email)).limit(1);
  
  if (resultado.length > 0) {
    const usuarioDb = resultado[0];
    
    if (usuarioDb.trialEndsAt) {
      const hoje = new Date();
      const fim = new Date(usuarioDb.trialEndsAt);
      const diferencaTempo = fim.getTime() - hoje.getTime();
      diasRestantes = Math.ceil(diferencaTempo / (1000 * 3600 * 24));
      
      if (diasRestantes <= 0) {
        isExpirado = true;
      }
    }
  }
}

const primeiroNome = session?.user?.name ? session.user.name.split(' ')[0] : 'Gestor';
const fotoPerfil = session?.user?.image;

const whatsappLink = `https://wa.me/5511957223955?text=Olá Matheus, meu acesso ao G STORM expirou e gostaria de renovar minha mensalidade para continuar usando o sistema no meu estúdio.`;
---

<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Painel - G STORM</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><rect width='100' height='100' rx='20' fill='%23000000'/><text x='50' y='72' font-family='system-ui, sans-serif' font-size='60' font-weight='900' text-anchor='middle'><tspan fill='%23ffffff'>G</tspan><tspan fill='%238b5cf6'>S</tspan></text></svg>" />
  </head>
  <body class="bg-gray-50 text-black flex h-screen font-sans overflow-hidden">
    
    <aside class="w-64 bg-black text-white flex-col hidden md:flex z-20">
      <div class="p-6 border-b border-gray-800">
        <h2 class="text-2xl font-extrabold tracking-tight">G <span class="text-purple-500">STORM</span></h2>
      </div>
      
      <nav class="flex-1 p-4 space-y-2">
        <a href="/dashboard" class={`flex items-center gap-3 px-4 py-3 rounded-xl transition-colors ${isExpirado ? 'opacity-50 cursor-not-allowed text-gray-500' : 'bg-purple-600 text-white'}`}>
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path></svg>
          Início
        </a>
        <a href="#" class={`flex items-center gap-3 px-4 py-3 rounded-xl transition-colors ${isExpirado ? 'opacity-50 cursor-not-allowed text-gray-500' : 'text-gray-400 hover:bg-gray-900 hover:text-white'}`}>
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
          Agendamentos
        </a>
        <a href="#" class={`flex items-center gap-3 px-4 py-3 rounded-xl transition-colors ${isExpirado ? 'opacity-50 cursor-not-allowed text-gray-500' : 'text-gray-400 hover:bg-gray-900 hover:text-white'}`}>
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path></svg>
          Clientes
        </a>
      </nav>
      
      <div class="p-4 border-t border-gray-800">
        <button id="btn-logout-desktop" class="w-full flex items-center gap-3 px-4 py-2 text-sm text-gray-400 hover:text-white transition-colors">
          Sair do sistema
        </button>
      </div>
    </aside>

    <div id="mobile-menu" class="fixed inset-0 z-50 bg-black/80 backdrop-blur-sm hidden transition-opacity">
      <div class="w-64 bg-black h-full shadow-2xl flex flex-col transform transition-transform">
        <div class="p-4 flex items-center justify-between border-b border-gray-800">
          <h2 class="text-xl font-extrabold text-white tracking-tight">G <span class="text-purple-500">STORM</span></h2>
          <button id="btn-close-menu" class="p-2 text-gray-400 hover:text-white">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
          </button>
        </div>
        
        <nav class="flex-1 p-4 space-y-2">
          <a href="/dashboard" class={`flex items-center gap-3 px-4 py-3 rounded-xl transition-colors ${isExpirado ? 'opacity-50 cursor-not-allowed text-gray-500' : 'bg-purple-600 text-white'}`}>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path></svg>
            Início
          </a>
          <a href="#" class={`flex items-center gap-3 px-4 py-3 rounded-xl transition-colors ${isExpirado ? 'opacity-50 cursor-not-allowed text-gray-500' : 'text-gray-400 hover:bg-gray-900 hover:text-white'}`}>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
            Agendamentos
          </a>
          <a href="#" class={`flex items-center gap-3 px-4 py-3 rounded-xl transition-colors ${isExpirado ? 'opacity-50 cursor-not-allowed text-gray-500' : 'text-gray-400 hover:bg-gray-900 hover:text-white'}`}>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path></svg>
            Clientes
          </a>
        </nav>
        
        <div class="p-4 border-t border-gray-800">
          <button id="btn-logout-mobile" class="w-full flex items-center gap-3 px-4 py-2 text-sm text-gray-400 hover:text-white transition-colors">
            Sair do sistema
          </button>
        </div>
      </div>
    </div>

    <main class="flex-1 flex flex-col h-screen overflow-y-auto relative w-full">
      
      <header class="bg-white shadow-sm p-4 flex items-center justify-between border-b border-gray-200 z-10 sticky top-0">
        <div class="flex items-center gap-3">
          <button id="btn-open-menu" class="md:hidden p-2 -ml-2 text-gray-600 hover:text-purple-600 focus:outline-none">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path></svg>
          </button>
          <h1 class="text-xl font-bold md:hidden">G <span class="text-purple-600">STORM</span></h1>
        </div>
        
        <div class="flex items-center gap-4">
          {!isExpirado && diasRestantes > 0 && (
            <div class="hidden sm:flex items-center gap-2 px-3 py-1.5 bg-purple-50 text-purple-700 rounded-full border border-purple-200 text-xs font-bold shadow-sm">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
              {diasRestantes} dias Pro
            </div>
          )}
          <span class="hidden sm:block text-sm font-semibold text-gray-700">Olá, {primeiroNome}</span>
          <img src={fotoPerfil} alt={primeiroNome} class="w-10 h-10 rounded-full border-2 border-purple-500 object-cover shadow-sm" referrerpolicy="no-referrer" />
        </div>
      </header>

      <div class="p-4 sm:p-6 md:p-8 relative h-full">
        {isExpirado ? (
          /* TELA DE BLOQUEIO */
          <div class="absolute inset-0 z-40 bg-white/95 backdrop-blur-md flex items-center justify-center p-6 text-center">
            <div class="max-w-md w-full">
              <div class="w-20 h-20 bg-purple-100 text-purple-600 rounded-full flex items-center justify-center mx-auto mb-6 shadow-inner">
                <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path></svg>
              </div>
              <h2 class="text-2xl sm:text-3xl font-black text-black mb-4">Período de Teste Encerrado</h2>
              <p class="text-sm sm:text-base text-gray-600 mb-8 leading-relaxed">
                Seus 15 dias de acesso cortesia ao <strong>G STORM PRO</strong> chegaram ao fim. Para continuar gerenciando sua estética automotiva, realize a ativação do seu plano mensal.
              </p>
              <a 
                href={whatsappLink} 
                target="_blank"
                class="flex items-center justify-center gap-3 w-full py-4 px-6 bg-purple-600 hover:bg-purple-700 text-white font-bold rounded-2xl transition-all shadow-lg shadow-purple-200"
              >
                <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L0 24l6.335-1.662c1.72.94 3.659 1.437 5.634 1.437h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
                Liberar Acesso via WhatsApp
              </a>
              <button 
                onclick="window.location.reload()"
                class="mt-6 text-sm text-gray-500 hover:text-gray-800 transition-colors underline"
              >
                Já paguei? Clique para atualizar
              </button>
            </div>
          </div>
        ) : (
          <slot />
        )}
      </div>
    </main>

  </body>
</html>

<script>
  import { signOut } from "auth-astro/client";
  
  // Controle de Logout (agora temos dois botões: mobile e desktop)
  const handleLogout = (e: Event) => {
    e.preventDefault();
    signOut({ callbackUrl: "/login" });
  };

  const logoutDesktop = document.getElementById("btn-logout-desktop");
  const logoutMobile = document.getElementById("btn-logout-mobile");
  
  if (logoutDesktop) logoutDesktop.addEventListener("click", handleLogout);
  if (logoutMobile) logoutMobile.addEventListener("click", handleLogout);

  // Controle do Menu Mobile
  const menuMobile = document.getElementById("mobile-menu");
  const btnOpen = document.getElementById("btn-open-menu");
  const btnClose = document.getElementById("btn-close-menu");

  if (menuMobile && btnOpen && btnClose) {
    btnOpen.addEventListener("click", () => {
      menuMobile.classList.remove("hidden");
    });
    
    btnClose.addEventListener("click", () => {
      menuMobile.classList.add("hidden");
    });
  }
</script>