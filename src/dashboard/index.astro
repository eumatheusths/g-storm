---
// src/pages/dashboard/index.astro
import DashboardLayout from '../../layouts/DashboardLayout.astro';
---

<DashboardLayout>
  <div class="mb-8">
    <h1 class="text-3xl font-bold text-gray-900">Visão Geral</h1>
    <p class="text-gray-500 mt-1">Acompanhe os resultados do Studio Marqé hoje.</p>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
    
    <div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100 border-l-4 border-l-purple-500">
      <h3 class="text-sm font-medium text-gray-500 mb-2">Agendamentos Hoje</h3>
      <p class="text-3xl font-bold text-gray-900">5</p>
    </div>

    <div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100 border-l-4 border-l-black">
      <h3 class="text-sm font-medium text-gray-500 mb-2">Faturamento Esperado</h3>
      <p class="text-3xl font-bold text-gray-900">R$ 1.250</p>
    </div>

    <div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100 border-l-4 border-l-gray-300">
      <h3 class="text-sm font-medium text-gray-500 mb-2">Novos Clientes</h3>
      <p class="text-3xl font-bold text-gray-900">2</p>
    </div>

  </div>
  
  <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6">
    <h2 class="text-lg font-bold text-gray-900 mb-4">Próximos Veículos</h2>
    <div class="text-center py-10 text-gray-400">
      Nenhum dado do banco de dados ainda.
    </div>
  </div>
</DashboardLayout>